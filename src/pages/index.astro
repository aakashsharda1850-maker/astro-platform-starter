---
const title = "Astro Akash SH | Expert Vedic Strategist";
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --gold: #d4af37; --dark: #0f0c29; --accent: #302b63; }
        body { font-family: 'Inter', sans-serif; line-height: 1.6; color: #fff; margin: 0; background: linear-gradient(135deg, #0f0c29, #302b63, #24243e); background-attachment: fixed; }
        .container { max-width: 1000px; margin: 0 auto; padding: 20px; }
        
        nav { display: flex; justify-content: space-between; align-items: center; padding: 20px 0; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .nav-links a { color: #fff; text-decoration: none; margin-left: 20px; font-weight: bold; }
        .nav-links a:hover { color: var(--gold); }

        .hero { text-align: center; padding: 80px 0; background: url('https://images.unsplash.com/photo-1534796636912-3b95b3ab5986?auto=format&fit=crop&w=1200&q=80') center/cover; border-radius: 20px; margin: 20px 0; border: 1px solid var(--gold); }
        .logo-circle { width: 90px; height: 90px; background: var(--gold); border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.8rem; color: #000; box-shadow: 0 0 30px rgba(212, 175, 55, 0.4); }

        .btn-grid { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; margin: 25px 0; }
        .btn { padding: 12px 22px; border-radius: 30px; text-decoration: none; font-weight: bold; color: #fff; transition: 0.3s; display: flex; align-items: center; gap: 8px; }
        .btn-call { background: #00b894; } .btn-wa { background: #25D366; } .btn-as { background: var(--gold); color: #000; }
        
        .pricing-section { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 40px 0; }
        .price-card { background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(15px); padding: 30px; border-radius: 20px; border: 1px solid var(--gold); }
        .price-item { display: flex; justify-content: space-between; margin: 15px 0; font-size: 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 5px; }

        .upi-section { background: #fff; color: #000; padding: 30px; border-radius: 20px; text-align: center; margin: 40px 0; }
        .upi-id { font-size: 1.4rem; font-weight: bold; color: #302b63; background: #eee; padding: 10px; border-radius: 10px; display: inline-block; margin: 10px 0; }
    </style>
</head>
<body>
    <div class="container">
        <nav>
            <div style="font-weight: bold; color: var(--gold);">ASTRO AKASH SH</div>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/about">Full Bio</a>
            </div>
        </nav>

        <header class="hero">
            <div class="logo-circle">A-SH</div>
            <h1 style="text-shadow: 2px 2px 10px #000;">Astro Akash SH</h1>
            <p>Decoding Your Destiny with Vedic Intelligence</p>
            <div class="btn-grid">
                <a href="tel:+918580672809" class="btn btn-call"><i class="fas fa-phone"></i> Call</a>
                <a href="https://wa.me/918580672809" class="btn btn-wa"><i class="fab fa-whatsapp"></i> Chat</a>
                <a href="https://varta.astrosage.com/astrologer/akashastrop0988?prtnr_id=" class="btn btn-as">AstroSage</a>
            </div>
        </header>

        <h2 style="text-align: center;">Consultation Offerings</h2>
        <div class="pricing-section">
            <div class="price-card">
                <h3 style="color: var(--gold);">Students 🎓</h3>
                <div class="price-item"><span>1 Question</span> <span>₹101</span></div>
                <div class="price-item"><span>2 Questions</span> <span>₹201</span></div>
                <div class="price-item"><span>Full Analysis</span> <span>₹501</span></div>
            </div>
            <div class="price-card">
                <h3 style="color: var(--gold);">Adults 💼</h3>
                <div class="price-item"><span>1 Question</span> <span>₹301</span></div>
                <div class="price-item"><span>2 Questions</span> <span>₹601</span></div>
                <div class="price-item"><span>Full Analysis</span> <span>₹1501</span></div>
            </div>
        </div>

        <div class="upi-section">
            <h3><i class="fas fa-wallet"></i> Secure Payment</h3>
            <p>Pay via any UPI App (GPay, PhonePe, Paytm)</p>
            <div class="upi-id">aakashsharda1850@oksbi</div>
            <p style="font-size: 0.8rem;">*Share screenshot on WhatsApp after payment</p>
        </div>

        <footer style="text-align: center; padding: 40px; color: var(--gold);">
            <p>&copy; 2026 Astro Akash SH | All Rights Reserved</p>
        </footer>
    </div>
</body>
</html>
