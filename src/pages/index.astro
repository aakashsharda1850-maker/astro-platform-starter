---
const title = "Astro Akash SH | Professional Vedic Strategist";
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --gold: #d4af37; --bg: #0b0d17; }
        body { 
            font-family: 'Inter', sans-serif; color: #fff; margin: 0; 
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1532968961962-8a0cb3a2d4f5?auto=format&fit=crop&w=1600&q=80');
            background-size: cover; background-attachment: fixed; line-height: 1.6;
        }
        .container { max-width: 1100px; margin: 0 auto; padding: 20px; }
        
        /* Navigation */
        nav { display: flex; justify-content: space-between; align-items: center; padding: 20px 0; }
        .nav-links a { color: var(--gold); text-decoration: none; font-weight: bold; margin-left: 20px; text-transform: uppercase; font-size: 0.8rem; }

        /* Hero Section */
        header { text-align: center; padding: 50px 0; }
        .logo-box { 
            width: 80px; height: 80px; background: var(--gold); border-radius: 50%; 
            margin: 0 auto 15px; display: flex; align-items: center; justify-content: center; 
            font-weight: bold; font-size: 1.5rem; color: #000; border: 4px solid #fff;
        }
        h1 { font-size: 3rem; margin: 10px 0; letter-spacing: 2px; }

        /* Buttons Grid */
        .btn-grid { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; margin: 30px 0; }
        .btn { padding: 12px 20px; border-radius: 50px; text-decoration: none; font-weight: bold; color: #fff; display: flex; align-items: center; gap: 8px; transition: 0.3s; }
        .btn-call { background: #2ecc71; } .btn-wa { background: #25D366; } .btn-ig { background: #E1306C; } .btn-as { background: #f39c12; }

        /* Content Sections */
        .glass-panel { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); padding: 40px; border-radius: 30px; border: 1px solid rgba(212, 175, 55, 0.2); margin: 30px 0; text-align: center; }
        .quote { font-size: 1.3rem; font-style: italic; color: var(--gold); }

        /* Pricing Table */
        .price-container { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 40px 0; }
        .price-card { background: rgba(0,0,0,0.5); padding: 30px; border-radius: 20px; border: 1px solid var(--gold); }
        .price-item { display: flex; justify-content: space-between; margin: 15px 0; font-size: 1.1rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 5px; }

        /* Payment Section */
        .payment-box { background: #fff; color: #000; padding: 40px; border-radius: 30px; text-align: center; }
        .qr-img { width: 220px; border-radius: 15px; margin: 20px 0; box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .upi-id { font-weight: 800; font-size: 1.2rem; color: #1a1a2e; background: #f0f0f0; padding: 10px 20px; border-radius: 10px; display: inline-block; }

        @media (max-width: 700px) { .price-container { grid-template-columns: 1fr; } h1 { font-size: 2.2rem; } }
    </style>
</head>
<body>

    <div class="container">
        <nav>
            <div style="font-weight: bold; color: var(--gold);">ASTRO AKASH SH</div>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/about">My Story</a>
            </div>
        </nav>

        <header>
            <div class="logo-box">A-SH</div>
            <h1>Astro Akash SH</h1>
            <p>Certified Astrologer | Vedic Intelligence Expert</p>
            
            <div class="btn-grid">
                <a href="tel:+918580672809" class="btn btn-call"><i class="fas fa-phone-alt"></i> Call</a>
                <a href="https://wa.me/918580672809" class="btn btn-wa"><i class="fab fa-whatsapp"></i> WhatsApp</a>
                <a href="https://varta.astrosage.com/astrologer/akashastrop0988?prtnr_id=" class="btn btn-as"><i class="fas fa-certificate"></i> AstroSage</a>
                <a href="https://www.instagram.com/astro_akash_sh?igsh=cnF4Zm51bTZ4eWox" class="btn btn-ig"><i class="fab fa-instagram"></i> Instagram</a>
            </div>
        </header>

        <div class="glass-panel">
            <p class="quote">"I don't believe the stars force you into a destiny. I believe astrology is a map, not a prison. Timing is the ultimate unfair advantage."</p>
        </div>

        <h2 style="text-align: center; color: var(--gold);">Consultation Plans</h2>
        <div class="price-container">
            <div class="price-card">
                <h3 style="color: var(--gold);">Students 🎓</h3>
                <div class="price-item"><span>1 Question</span> <span>₹101</span></div>
                <div class="price-item"><span>2 Questions</span> <span>₹201</span></div>
                <div class="price-item"><span>Full Analysis</span> <span>₹501</span></div>
            </div>
            <div class="price-card">
                <h3 style="color: var(--gold);">Adults 💼</h3>
                <div class="price-item"><span>1 Question</span> <span>₹301</span></div>
                <div class="price-item"><span>2 Questions</span> <span>₹601</span></div>
                <div class="price-item"><span>Full Analysis</span> <span>₹1501</span></div>
            </div>
        </div>

        <div class="payment-box">
            <h3><i class="fas fa-qrcode"></i> Instant Payment</h3>
            <p>Scan the QR below to pay via GPay, PhonePe, or Paytm</p>
            <img src="/qr.png" class="qr-img" alt="UPI QR Code" />
            <br/>
            <div class="upi-id">aakashsharda1850@oksbi</div>
            <p style="font-size: 0.8rem; color: #666; margin-top: 15px;">*Kindly send the screenshot on WhatsApp after payment for confirmation.</p>
        </div>

        <footer style="text-align: center; padding: 50px 0; color: var(--gold); opacity: 0.6;">
            <p>&copy; 2026 Astro Akash SH | Decoding Patterns, Creating Success.</p>
        </footer>
    </div>

</body>
</html>
