---
const title = "Astro Akash SH | Expert Vedic Strategist";
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --gold: #d4af37; --dark: #0f0c29; --accent: #302b63; }
        body { 
            font-family: 'Inter', sans-serif; 
            line-height: 1.6; 
            color: #fff; 
            margin: 0; 
            background: linear-gradient(to bottom, #0f0c29, #302b63, #24243e);
            background-attachment: fixed;
        }
        .container { max-width: 1000px; margin: 0 auto; padding: 20px; }
        
        /* Logo Styling */
        .logo-circle {
            width: 80px; height: 80px; background: var(--gold); border-radius: 50%;
            margin: 20px auto; display: flex; align-items: center; justify-content: center;
            font-weight: bold; font-size: 1.5rem; color: #000; border: 3px solid #fff;
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.5);
        }

        header { text-align: center; padding: 40px 0; }
        h1 { font-size: 2.8rem; margin: 10px 0; letter-spacing: 2px; text-transform: uppercase; }
        
        .contact-bar { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; margin: 20px 0; }
        .btn { padding: 12px 20px; border-radius: 30px; text-decoration: none; font-weight: bold; color: #fff; transition: 0.3s; display: flex; align-items: center; gap: 8px; font-size: 0.9rem; }
        .btn-call { background: #00b894; }
        .btn-wa { background: #25D366; }
        .btn-ig { background: #E1306C; }
        .btn-as { background: var(--gold); color: #000; }

        .pricing-section { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 40px 0; }
        .price-card { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); padding: 25px; border-radius: 15px; border: 1px solid rgba(212, 175, 55, 0.3); }
        .price-card h3 { color: var(--gold); border-bottom: 1px solid var(--gold); padding-bottom: 10px; }
        .price-item { display: flex; justify-content: space-between; margin: 15px 0; font-size: 1.1rem; }
        
        .philosophy { text-align: center; padding: 40px; background: rgba(0,0,0,0.3); border-radius: 20px; margin: 40px 0; }
        
        @media (max-width: 600px) { .pricing-section { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <div class="logo-circle">A-SH</div>
            <h1>Astro Akash SH</h1>
            <p style="color: var(--gold)">Vedic Wisdom meets Modern Strategy</p>
            
            <div class="contact-bar">
                <a href="tel:+918580672809" class="btn btn-call"><i class="fas fa-phone"></i> Call Now</a>
                <a href="https://wa.me/918580672809" class="btn btn-wa"><i class="fab fa-whatsapp"></i> WhatsApp</a>
                <a href="https://varta.astrosage.com/astrologer/akashastrop0988?prtnr_id=" class="btn btn-as"><i class="fas fa-star"></i> AstroSage Profile</a>
                <a href="https://www.instagram.com/astro_akash_sh?igsh=cnF4Zm51bTZ4eWox" class="btn btn-ig"><i class="fab fa-instagram"></i> Instagram</a>
            </div>
        </header>

        <section class="philosophy">
            <h2>The Cosmic Blueprint</h2>
            <p>"I don't believe the stars force you into a destiny. I believe astrology is a map, not a prison. Timing is the ultimate unfair advantage."</p>
        </section>

        <h2 style="text-align: center;">Consultation Plans</h2>
        <div class="pricing-section">
            <div class="price-card">
                <h3>Students 🎓</h3>
                <div class="price-item"><span>1 Question</span> <span>₹101</span></div>
                <div class="price-item"><span>2 Questions</span> <span>₹201</span></div>
                <div class="price-item"><span>Full Analysis</span> <span>₹501</span></div>
            </div>
            <div class="price-card">
                <h3>Adults 💼</h3>
                <div class="price-item"><span>1 Question</span> <span>₹301</span></div>
                <div class="price-item"><span>2 Questions</span> <span>₹601</span></div>
                <div class="price-item"><span>Full Analysis</span> <span>₹1501</span></div>
            </div>
        </div>

        <div style="text-align: center; margin-top: 50px;">
            <p>&copy; 2026 Astro Akash SH | Trusted on AstroSage</p>
        </div>
    </div>

</body>
</html>
