---
const title = "Professional Services | Akash Astrologic";
---
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --gold: #d4af37; }
        body { font-family: 'Inter', sans-serif; color: #fff; margin: 0; background: linear-gradient(rgba(0,0,0,0.9), rgba(0,0,0,0.9)), url('https://images.unsplash.com/photo-1506318137071-a8e063b4bc04?auto=format&fit=crop&w=1200&q=80'); background-size: cover; background-attachment: fixed; }
        .container { max-width: 900px; margin: 0 auto; padding: 20px; }
        nav { display: flex; justify-content: center; gap: 20px; padding: 20px 0; border-bottom: 1px solid rgba(212,175,55,0.2); margin-bottom: 30px; }
        nav a { color: var(--gold); text-decoration: none; font-weight: bold; text-transform: uppercase; font-size: 0.9rem; }
        .service-card { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); padding: 30px; border-radius: 20px; border: 1px solid rgba(212, 175, 55, 0.2); margin-bottom: 20px; }
        h2 { color: var(--gold); }
    </style>
</head>
<body>
    <div class="container">
        <nav>
            <a href="/">Home</a>
            <a href="/about">Journey</a>
            <a href="/services">Services</a>
        </nav>
        <h1 style="text-align: center; color: var(--gold);">Expert Strategy</h1>
        <div class="service-card">
            <h2>Career & Business Timing</h2>
            <p>I analyze ur Dashas to find the exact window for ur next big move.</p>
        </div>
    </div>
</body>
</html>
