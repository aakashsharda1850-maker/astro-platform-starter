---
const title = "Contact | Akash Astrologic";
---
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --gold: #d4af37; }
        body { 
            font-family: 'Inter', sans-serif; color: #fff; margin: 0; 
            background: linear-gradient(rgba(0,0,0,0.9), rgba(0,0,0,0.9)), url('https://images.unsplash.com/photo-1423666639041-f56000c27a9a?auto=format&fit=crop&w=1200&q=80');
            background-size: cover; background-attachment: fixed; line-height: 1.6;
        }
        .container { max-width: 900px; margin: 0 auto; padding: 20px; }
        
        nav { display: flex; justify-content: center; gap: 20px; padding: 25px 0; border-bottom: 1px solid rgba(212, 175, 55, 0.2); margin-bottom: 40px; flex-wrap: wrap; }
        nav a { color: var(--gold); text-decoration: none; font-weight: bold; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; }
        
        .trust-section { text-align: center; margin-bottom: 50px; padding: 20px; }
        .trust-section h1 { color: var(--gold); font-size: 2.5rem; margin-bottom: 15px; }
        .trust-text { font-size: 1.2rem; color: #eee; max-width: 700px; margin: 0 auto; line-height: 1.8; }

        .contact-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .contact-card { 
            background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); 
            padding: 30px; border-radius: 25px; border: 1px solid rgba(212, 175, 55, 0.1); 
            text-align: center; transition: 0.3s;
        }
        .contact-card:hover { border-color: var(--gold); transform: translateY(-5px); }
        .contact-card i { font-size: 2rem; color: var(--gold); margin-bottom: 15px; }
        .contact-link { color: #fff; text-decoration: none; font-size: 1.1rem; font-weight: bold; display: block; margin-top: 10px; }

        /* Random Quote Box */
        .quote-container { background: rgba(212, 175, 55, 0.1); border: 2px solid var(--gold); padding: 40px; border-radius: 30px; text-align: center; margin-top: 20px; }
        #quote-text { font-size: 1.4rem; font-style: italic; color: #fff; display: block; margin-bottom: 10px; }
        #quote-author { color: var(--gold); font-weight: bold; text-transform: uppercase; letter-spacing: 1px; }
    </style>
</head>
<body>
    <div class="container">
        <nav>
            <a href="/">Home</a>
            <a href="/about">Journey</a>
            <a href="/services">Services</a>
            <a href="/reviews">Reviews</a>
            <a href="/contact">Contact</a>
        </nav>
        
        <div class="trust-section">
            <h1>Let's Talk Results</h1>
            <p class="trust-text">
                "I don't just read charts; I decode timing. Thousands have trusted me on <strong>AstroSage</strong> because my logic is backed by results, not just rituals. Your investment is an investment in your own clarity and peace of mind. If you are ready for the truth, I am ready to guide you."
            </p>
        </div>

        <div class="contact-grid">
            <a href="https://wa.me/918580672809" style="text-decoration:none">
                <div class="contact-card">
                    <i class="fab fa-whatsapp"></i>
                    <h3>WhatsApp</h3>
                    <p class="contact-link">Message Directly</p>
                </div>
            </a>

            <a href="https://www.instagram.com/astro_akash_sh?igsh=cnF4Zm51bTZ4eWox" style="text-decoration:none">
                <div class="contact-card">
                    <i class="fab fa-instagram"></i>
                    <h3>Instagram</h3>
                    <p class="contact-link">Follow the Energy</p>
                </div>
            </a>

            <a href="mailto:aakashsharda1850@gmail.com" style="text-decoration:none">
                <div class="contact-card">
                    <i class="fas fa-envelope"></i>
                    <h3>Gmail</h3>
                    <p class="contact-link">Send Query</p>
                </div>
            </a>
        </div>

        <div class="quote-container">
            <h3 style="color: var(--gold); margin-top:0"><i class="fas fa-bolt"></i> Daily Cosmic Insight</h3>
            <span id="quote-text">"Loading your insight..."</span>
            <span id="quote-author"></span>
        </div>

        <footer style="text-align: center; padding: 60px 0; color: var(--gold); opacity: 0.5; font-size: 0.8rem;">
            <p>© 2026 Akash Astrologic | Real Logic. Real Light.</p>
        </footer>
    </div>

    <script>
        const quotes = [
            { text: "Hard work is the fuel, but Timing is the engine.", author: "Vedic Wisdom" },
            { text: "Do not plant your seeds in winter and complain about the harvest.", author: "Akash Astrologic" },
            { text: "The universe doesn't speak English; it speaks frequency.", author: "Cosmic Law" },
            { text: "Clarity is the ultimate weapon in a world of chaos.", author: "Strategy" },
            { text: "Your birth chart is the map, but you are the driver.", author: "Ancient Truth" },
            { text: "Alignment beats hustle every single time.", author: "Logic to Light" }
        ];

        function getRandomQuote() {
            const randomIndex = Math.floor(Math.random() * quotes.length);
            const quote = quotes[randomIndex];
            document.getElementById('quote-text').innerText = "${quote.text}";
            document.getElementById('quote-author').innerText = - ${quote.author};
        }

        // Run on load
        getRandomQuote();
    </script>
</body>
</html>
