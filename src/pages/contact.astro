---
const title = "Contact | Akash Astrologic";
---
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --gold: #d4af37; }
        body { 
            font-family: 'Inter', sans-serif; color: #fff; margin: 0; 
            background: linear-gradient(rgba(0,0,0,0.9), rgba(0,0,0,0.9)), url('https://images.unsplash.com/photo-1423666639041-f56000c27a9a?auto=format&fit=crop&w=1200&q=80');
            background-size: cover; background-attachment: fixed; line-height: 1.6;
        }
        .container { max-width: 900px; margin: 0 auto; padding: 20px; }
        nav { display: flex; justify-content: center; gap: 20px; padding: 25px 0; border-bottom: 1px solid rgba(212, 175, 55, 0.2); margin-bottom: 40px; flex-wrap: wrap; }
        nav a { color: var(--gold); text-decoration: none; font-weight: bold; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; }
        
        .trust-section { text-align: center; margin-bottom: 50px; padding: 30px; background: rgba(255, 255, 255, 0.05); border-radius: 30px; border: 1px solid var(--gold); }
        .trust-section h1 { color: var(--gold); font-size: 2.2rem; margin-bottom: 15px; }

        .contact-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .contact-card { background: rgba(255, 255, 255, 0.05); padding: 30px; border-radius: 25px; border: 1px solid rgba(212, 175, 55, 0.1); text-align: center; transition: 0.3s; }
        .contact-card:hover { border-color: var(--gold); transform: translateY(-5px); }
        .contact-card i { font-size: 2rem; color: var(--gold); margin-bottom: 15px; }
        .contact-link { color: #fff; text-decoration: none; font-weight: bold; display: block; }

        .quote-container { background: rgba(212, 175, 55, 0.15); border: 2px solid var(--gold); padding: 40px; border-radius: 30px; text-align: center; }
        #quote-text { font-size: 1.4rem; font-style: italic; display: block; margin-bottom: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <nav>
            <a href="/">Home</a>
            <a href="/about">Journey</a>
            <a href="/services">Services</a>
            <a href="/reviews">Reviews</a>
            <a href="/contact">Contact</a>
        </nav>
        
        <div class="trust-section">
            <h1>Expert Vedic Strategy</h1>
            <p>"I don't just read charts; i decode timing. Thousands trust me on <strong>AstroSage</strong> because my logic is backed by results. Your investment is an investment in ur own clarity. If ur ready for the truth, i'm ready to guide u."</p>
        </div>

        <div class="contact-grid">
            <a href="https://wa.me/918580672809" style="text-decoration:none">
                <div class="contact-card"><i class="fab fa-whatsapp"></i><h3>WhatsApp</h3><span class="contact-link">Chat Now</span></div>
            </a>
            <a href="https://www.instagram.com/astro_akash_sh" style="text-decoration:none">
                <div class="contact-card"><i class="fab fa-instagram"></i><h3>Instagram</h3><span class="contact-link">Follow Me</span></div>
            </a>
            <a href="mailto:aakashsharda1850@gmail.com" style="text-decoration:none">
                <div class="contact-card"><i class="fas fa-envelope"></i><h3>Gmail</h3><span class="contact-link">Email Me</span></div>
            </a>
        </div>

        <div class="quote-container">
            <h3 style="color: var(--gold); margin-top:0">Daily Insight</h3>
            <span id="quote-text">"Hard work is the fuel, but Timing is the engine."</span>
            <span id="quote-author" style="color:var(--gold); font-weight:bold;">- Vedic Wisdom</span>
        </div>
    </div>

    <script is:inline>
        const quotes = [
            { t: "Alignment beats hustle every single time.", a: "Logic to Light" },
            { t: "Do not plant seeds in winter and complain about the harvest.", a: "Akash Astrologic" },
            { t: "The universe speaks in frequency, not English.", a: "Cosmic Law" },
            { t: "Your birth chart is the map, but you are the driver.", a: "Ancient Truth" }
        ];
        const q = quotes[Math.floor(Math.random() * quotes.length)];
        const textEl = document.getElementById('quote-text');
        const authEl = document.getElementById('quote-author');
        if (textEl && authEl) {
            textEl.innerText = '"' + q.t + '"';
            authEl.innerText = '- ' + q.a;
        }
    </script>
</body>
</html>
