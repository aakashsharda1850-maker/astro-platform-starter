---
const title = "Contact | Akash Astrologic";
---
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --gold: #d4af37; }
        body { 
            font-family: 'Inter', sans-serif; color: #fff; margin: 0; 
            background: linear-gradient(rgba(0,0,0,0.9), rgba(0,0,0,0.9)), url('https://images.unsplash.com/photo-1423666639041-f56000c27a9a?auto=format&fit=crop&w=1200&q=80');
            background-size: cover; background-attachment: fixed; line-height: 1.6;
        }
        .container { max-width: 900px; margin: 0 auto; padding: 20px; }
        
        /* Matching Nav */
        nav { display: flex; justify-content: center; gap: 20px; padding: 25px 0; border-bottom: 1px solid rgba(212, 175, 55, 0.2); margin-bottom: 40px; flex-wrap: wrap; }
        nav a { color: var(--gold); text-decoration: none; font-weight: bold; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; }
        
        .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 20px; }
        .contact-card { 
            background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); 
            padding: 30px; border-radius: 25px; border: 1px solid rgba(212, 175, 55, 0.1); 
            text-align: center;
        }
        .contact-card i { font-size: 2rem; color: var(--gold); margin-bottom: 15px; }
        .contact-link { color: #fff; text-decoration: none; font-size: 1.1rem; font-weight: bold; display: block; margin-top: 10px; transition: 0.3s; }
        .contact-link:hover { color: var(--gold); }

        .map-box { margin-top: 30px; border-radius: 25px; overflow: hidden; border: 1px solid var(--gold); height: 300px; }
        iframe { width: 100%; height: 100%; border: none; filter: grayscale(1) invert(1) contrast(1.2); }

        @media (max-width: 700px) { .contact-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
    <div class="container">
        <nav>
            <a href="/">Home</a>
            <a href="/about">Journey</a>
            <a href="/services">Services</a>
            <a href="/reviews">Reviews</a>
            <a href="/contact">Contact</a>
        </nav>
        
        <h1 style="text-align: center; color: var(--gold);">Get In Touch</h1>
        <p style="text-align: center; color: #ccc;">Align your cosmic strategy today.</p>

        <div class="contact-grid">
            <div class="contact-card">
                <i class="fab fa-whatsapp"></i>
                <h3>WhatsApp</h3>
                <p>For quick bookings & queries</p>
                <a href="https://wa.me/918580672809" class="contact-link">+91 85806 72809</a>
            </div>

            <div class="contact-card">
                <i class="fas fa-envelope"></i>
                <h3>Email</h3>
                <p>For business & detailed reports</p>
                <a href="mailto:aakashsharda1850@gmail.com" class="contact-link">aakashsharda1850@gmail.com</a>
            </div>
        </div>

        <div class="contact-card" style="margin-top: 30px;">
            <i class="fas fa-map-marker-alt"></i>
            <h3>Consultation Hub</h3>
            <p>Himachal Pradesh, India</p>
            <div class="map-box">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3403.5432!2d76.22!3d31.5!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x391ac3c6b0000001%3A0x123456789!2sHimachal%20Pradesh!5e0!3m2!1sen!2sin!4v1620000000000!5m2!1sen!2sin"></iframe>
            </div>
        </div>

        <footer style="text-align: center; padding: 40px 0; color: var(--gold); opacity: 0.5; font-size: 0.8rem;">
            <p>&copy; 2026 Akash Astrologic | From Logic to Light.</p>
        </footer>
    </div>
</body>
</html>
